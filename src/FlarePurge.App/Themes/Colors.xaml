<!--
  FlarePurge.App — Color tokens
  Usar vía ThemeResource: {ThemeResource FPAccentBrush}

  Lookup: incluir en App.xaml:
    <ResourceDictionary.MergedDictionaries>
      <ResourceDictionary Source="/Themes/Colors.xaml"/>
      <ResourceDictionary Source="/Themes/Typography.xaml"/>
    </ResourceDictionary.MergedDictionaries>
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- ═══════════════════════════════════════════════════════════════
             LIGHT
             ═══════════════════════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Light">

            <!-- Accent -->
            <Color x:Key="FPAccent">#F38020</Color>
            <Color x:Key="FPAccentHover">#D96A10</Color>
            <Color x:Key="FPAccentSubtle">#FFF4E6</Color>
            <Color x:Key="FPTextOnAccent">#FFFFFF</Color>

            <!-- Mica surfaces -->
            <Color x:Key="FPMicaBase">#F3F3F3</Color>
            <Color x:Key="FPMicaCard">#FBFBFB</Color>
            <Color x:Key="FPMicaPanel">#EEEEEE</Color>
            <Color x:Key="FPSurface">#FFFFFF</Color>

            <!-- Borders -->
            <Color x:Key="FPBorderNeutral">#E5E5E5</Color>
            <Color x:Key="FPBorderSubtle">#ECECEC</Color>

            <!-- Text -->
            <Color x:Key="FPTextPrimary">#1A1A1A</Color>
            <Color x:Key="FPTextSecondary">#5C5C5C</Color>
            <Color x:Key="FPTextTertiary">#8A8A8A</Color>

            <!-- Semantic -->
            <Color x:Key="FPSuccess">#0E7D3A</Color>
            <Color x:Key="FPSuccessSubtle">#E6F4EB</Color>
            <Color x:Key="FPDanger">#C42B1C</Color>
            <Color x:Key="FPDangerSubtle">#FDECEC</Color>

            <!-- Brushes (what you bind to) -->
            <SolidColorBrush x:Key="FPAccentBrush" Color="{StaticResource FPAccent}"/>
            <SolidColorBrush x:Key="FPAccentHoverBrush" Color="{StaticResource FPAccentHover}"/>
            <SolidColorBrush x:Key="FPAccentSubtleBrush" Color="{StaticResource FPAccentSubtle}"/>
            <SolidColorBrush x:Key="FPTextOnAccentBrush" Color="{StaticResource FPTextOnAccent}"/>
            <SolidColorBrush x:Key="FPMicaBaseBrush" Color="{StaticResource FPMicaBase}"/>
            <SolidColorBrush x:Key="FPMicaCardBrush" Color="{StaticResource FPMicaCard}"/>
            <SolidColorBrush x:Key="FPMicaPanelBrush" Color="{StaticResource FPMicaPanel}"/>
            <SolidColorBrush x:Key="FPSurfaceBrush" Color="{StaticResource FPSurface}"/>
            <SolidColorBrush x:Key="FPBorderNeutralBrush" Color="{StaticResource FPBorderNeutral}"/>
            <SolidColorBrush x:Key="FPBorderSubtleBrush" Color="{StaticResource FPBorderSubtle}"/>
            <SolidColorBrush x:Key="FPTextPrimaryBrush" Color="{StaticResource FPTextPrimary}"/>
            <SolidColorBrush x:Key="FPTextSecondaryBrush" Color="{StaticResource FPTextSecondary}"/>
            <SolidColorBrush x:Key="FPTextTertiaryBrush" Color="{StaticResource FPTextTertiary}"/>
            <SolidColorBrush x:Key="FPSuccessBrush" Color="{StaticResource FPSuccess}"/>
            <SolidColorBrush x:Key="FPSuccessSubtleBrush" Color="{StaticResource FPSuccessSubtle}"/>
            <SolidColorBrush x:Key="FPDangerBrush" Color="{StaticResource FPDanger}"/>
            <SolidColorBrush x:Key="FPDangerSubtleBrush" Color="{StaticResource FPDangerSubtle}"/>
        </ResourceDictionary>

        <!-- ═══════════════════════════════════════════════════════════════
             DARK
             ═══════════════════════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Dark">

            <!-- Accent: fijo en ambos temas (política cross-platform) -->
            <Color x:Key="FPAccent">#F38020</Color>
            <Color x:Key="FPAccentHover">#FF9A3D</Color>
            <Color x:Key="FPAccentSubtle">#3A2410</Color>
            <Color x:Key="FPTextOnAccent">#FFFFFF</Color>

            <!-- Mica surfaces -->
            <Color x:Key="FPMicaBase">#1F1F1F</Color>
            <Color x:Key="FPMicaCard">#2B2B2B</Color>
            <Color x:Key="FPMicaPanel">#323232</Color>
            <Color x:Key="FPSurface">#2E2E2E</Color>

            <!-- Borders -->
            <Color x:Key="FPBorderNeutral">#3A3A3A</Color>
            <Color x:Key="FPBorderSubtle">#353535</Color>

            <!-- Text -->
            <Color x:Key="FPTextPrimary">#F5F5F5</Color>
            <Color x:Key="FPTextSecondary">#B8B8B8</Color>
            <Color x:Key="FPTextTertiary">#8A8A8A</Color>

            <!-- Semantic -->
            <Color x:Key="FPSuccess">#3EC46F</Color>
            <Color x:Key="FPSuccessSubtle">#0F2A1A</Color>
            <Color x:Key="FPDanger">#F56565</Color>
            <Color x:Key="FPDangerSubtle">#3A1818</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="FPAccentBrush" Color="{StaticResource FPAccent}"/>
            <SolidColorBrush x:Key="FPAccentHoverBrush" Color="{StaticResource FPAccentHover}"/>
            <SolidColorBrush x:Key="FPAccentSubtleBrush" Color="{StaticResource FPAccentSubtle}"/>
            <SolidColorBrush x:Key="FPTextOnAccentBrush" Color="{StaticResource FPTextOnAccent}"/>
            <SolidColorBrush x:Key="FPMicaBaseBrush" Color="{StaticResource FPMicaBase}"/>
            <SolidColorBrush x:Key="FPMicaCardBrush" Color="{StaticResource FPMicaCard}"/>
            <SolidColorBrush x:Key="FPMicaPanelBrush" Color="{StaticResource FPMicaPanel}"/>
            <SolidColorBrush x:Key="FPSurfaceBrush" Color="{StaticResource FPSurface}"/>
            <SolidColorBrush x:Key="FPBorderNeutralBrush" Color="{StaticResource FPBorderNeutral}"/>
            <SolidColorBrush x:Key="FPBorderSubtleBrush" Color="{StaticResource FPBorderSubtle}"/>
            <SolidColorBrush x:Key="FPTextPrimaryBrush" Color="{StaticResource FPTextPrimary}"/>
            <SolidColorBrush x:Key="FPTextSecondaryBrush" Color="{StaticResource FPTextSecondary}"/>
            <SolidColorBrush x:Key="FPTextTertiaryBrush" Color="{StaticResource FPTextTertiary}"/>
            <SolidColorBrush x:Key="FPSuccessBrush" Color="{StaticResource FPSuccess}"/>
            <SolidColorBrush x:Key="FPSuccessSubtleBrush" Color="{StaticResource FPSuccessSubtle}"/>
            <SolidColorBrush x:Key="FPDangerBrush" Color="{StaticResource FPDanger}"/>
            <SolidColorBrush x:Key="FPDangerSubtleBrush" Color="{StaticResource FPDangerSubtle}"/>
        </ResourceDictionary>

        <!-- ═══════════════════════════════════════════════════════════════
             HIGH CONTRAST (accessibility — stub; fallback a Dark)
             ═══════════════════════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="FPAccentBrush" ResourceKey="SystemColorHighlightColorBrush"/>
            <StaticResource x:Key="FPTextPrimaryBrush" ResourceKey="SystemColorWindowTextColorBrush"/>
            <StaticResource x:Key="FPTextSecondaryBrush" ResourceKey="SystemColorGrayTextColorBrush"/>
            <StaticResource x:Key="FPSurfaceBrush" ResourceKey="SystemColorWindowColorBrush"/>
            <StaticResource x:Key="FPMicaBaseBrush" ResourceKey="SystemColorWindowColorBrush"/>
            <StaticResource x:Key="FPMicaCardBrush" ResourceKey="SystemColorWindowColorBrush"/>
            <StaticResource x:Key="FPMicaPanelBrush" ResourceKey="SystemColorWindowColorBrush"/>
            <StaticResource x:Key="FPBorderNeutralBrush" ResourceKey="SystemColorWindowTextColorBrush"/>
            <StaticResource x:Key="FPBorderSubtleBrush" ResourceKey="SystemColorWindowTextColorBrush"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══════════════════════════════════════════════════════════════════
         Shared numeric tokens (independientes de tema)
         ═══════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="FPRadiusCard">8</x:Double>
    <x:Double x:Key="FPRadiusControl">4</x:Double>
    <x:Double x:Key="FPRadiusPill">999</x:Double>

    <Thickness x:Key="FPBorderHairline">1</Thickness>
    <Thickness x:Key="FPBorderAccent">2</Thickness>

    <!-- Spacing scale (paralelo a FPSpacing Mac) -->
    <x:Double x:Key="FPSpace1">4</x:Double>
    <x:Double x:Key="FPSpace2">8</x:Double>
    <x:Double x:Key="FPSpace3">12</x:Double>
    <x:Double x:Key="FPSpace4">16</x:Double>
    <x:Double x:Key="FPSpace5">20</x:Double>
    <x:Double x:Key="FPSpace6">24</x:Double>
    <x:Double x:Key="FPSpace8">32</x:Double>
    <x:Double x:Key="FPSpace10">40</x:Double>

    <CornerRadius x:Key="FPCornerCard">8</CornerRadius>
    <CornerRadius x:Key="FPCornerControl">4</CornerRadius>
    <CornerRadius x:Key="FPCornerPill">999</CornerRadius>

</ResourceDictionary>
