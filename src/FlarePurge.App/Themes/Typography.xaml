<!--
  FlarePurge.App — Typography tokens
  Paralelo al FPFont de Mac. Segoe UI Variable + Cascadia Code.
  Uso: <TextBlock Style="{StaticResource FPTitleLargeStyle}" Text="..."/>
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         Font families
         - Segoe UI Variable: Win11+ (soporte nativo pesos + optical sizes)
         - Segoe UI: Win10 fallback automático
         - Cascadia Code: tokens, IDs, URLs monospace
         ═══════════════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="FPFontSans">Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="FPFontMono">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════════════
         Font sizes — escala 1:1 con los mockups
         ═══════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="FPFontSizeXSmall">10</x:Double>      <!-- overline / eyebrow / caps labels -->
    <x:Double x:Key="FPFontSizeSmall">11</x:Double>       <!-- metadata / footer text -->
    <x:Double x:Key="FPFontSizeBody">12</x:Double>        <!-- secondary body / labels -->
    <x:Double x:Key="FPFontSizeBodyMd">13</x:Double>      <!-- body primario -->
    <x:Double x:Key="FPFontSizeBodyLg">14</x:Double>      <!-- body grande / row titles -->
    <x:Double x:Key="FPFontSizeTitle">15</x:Double>       <!-- card titles -->
    <x:Double x:Key="FPFontSizeH3">18</x:Double>          <!-- section headings -->
    <x:Double x:Key="FPFontSizeH2">22</x:Double>          <!-- page titles "Zonas" -->
    <x:Double x:Key="FPFontSizeH1">26</x:Double>          <!-- hero "colorvivo.com" -->
    <x:Double x:Key="FPFontSizeDisplay">28</x:Double>     <!-- settings page title -->

    <!-- ═══════════════════════════════════════════════════════════════════
         Styles — aplica como Style en TextBlock
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Display — used in Settings page title "General" -->
    <Style x:Key="FPDisplayStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeDisplay}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

    <!-- H1 — hero zone name -->
    <Style x:Key="FPH1Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeH1}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- H2 — "Zonas" en la lista -->
    <Style x:Key="FPH2Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeH2}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- H3 — section heading dentro de settings / cards -->
    <Style x:Key="FPH3Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeH3}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- Card title — "Purgar todo", "Acerca de", etc -->
    <Style x:Key="FPTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- Body large — zone row title, settings row label -->
    <Style x:Key="FPBodyLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeBodyLg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- Body medium — default text -->
    <Style x:Key="FPBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeBodyMd}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <!-- Body secondary — description text under titles -->
    <Style x:Key="FPBodySecondaryStyle" TargetType="TextBlock"
           BasedOn="{StaticResource FPBodyStyle}">
        <Setter Property="Foreground" Value="{ThemeResource FPTextSecondaryBrush}"/>
    </Style>

    <!-- Caption — small metadata -->
    <Style x:Key="FPCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeBody}"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextSecondaryBrush}"/>
    </Style>

    <!-- Caption tertiary — metadata rows, footer labels -->
    <Style x:Key="FPCaptionTertiaryStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeSmall}"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextTertiaryBrush}"/>
    </Style>

    <!-- Overline / eyebrow — "§ ZONAS", "CUENTA", "PUBLICADO POR" -->
    <Style x:Key="FPOverlineStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeXSmall}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="CharacterSpacing" Value="80"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextTertiaryBrush}"/>
    </Style>

    <!-- Mono — IDs de zona, URLs, tokens, versiones -->
    <Style x:Key="FPMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontMono}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeBody}"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="FPMonoSmallStyle" TargetType="TextBlock"
           BasedOn="{StaticResource FPMonoStyle}">
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeXSmall}"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextTertiaryBrush}"/>
    </Style>

    <!-- Pill text — for status pills like ACTIVE, NO SE PUEDE DESHACER -->
    <Style x:Key="FPPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeXSmall}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="CharacterSpacing" Value="50"/>
    </Style>

    <!-- Accent button text — orange CTAs -->
    <Style x:Key="FPAccentButtonTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeBodyMd}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource FPTextOnAccentBrush}"/>
    </Style>

    <!-- Hero orange+black name "FlarePurge" en About -->
    <Style x:Key="FPHeroBrandStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FPFontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource FPFontSizeH2}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
