<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FlarePurge.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FlarePurge.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Estilos base WinUI 3 -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <!-- Tokens de FlarePurge -->
                <ResourceDictionary Source="ms-appx:///Themes/Colors.xaml"/>
                <ResourceDictionary Source="ms-appx:///Themes/Typography.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
