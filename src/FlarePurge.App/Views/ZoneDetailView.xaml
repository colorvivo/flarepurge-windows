<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FlarePurge.App.Views.ZoneDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FlarePurge.App.Views"
    xmlns:loc="using:FlarePurge.App.Localization">

    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator Key="Escape" Invoked="OnEscape"/>
        <KeyboardAccelerator Key="P" Modifiers="Control,Shift" Invoked="OnCtrlShiftP"/>
    </UserControl.KeyboardAccelerators>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="24" RowSpacing="16" MaxWidth="720" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.Zone.Name}"
                                   Style="{StaticResource FPH1Style}"
                                   Foreground="{ThemeResource FPTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Padding="8,2"
                                VerticalAlignment="Center"
                                CornerRadius="{StaticResource FPCornerPill}"
                                Background="{ThemeResource FPSuccessSubtleBrush}">
                            <TextBlock Text="{x:Bind ViewModel.Zone.StatusDisplay}"
                                       Style="{StaticResource FPPillTextStyle}"
                                       Foreground="{ThemeResource FPSuccessBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="{x:Bind loc:L.S('zoneDetail_overline_zoneId'), Mode=OneTime}"
                               Style="{StaticResource FPOverlineStyle}"
                               Foreground="{ThemeResource FPTextTertiaryBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="{x:Bind ViewModel.Zone.Id}"
                               Style="{StaticResource FPMonoSmallStyle}"
                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                               IsTextSelectionEnabled="True"/>
                </StackPanel>
            </Grid>

            <!-- Subtitle -->
            <TextBlock Grid.Row="1"
                       Text="{x:Bind local:ZoneDetailView.AccountSubtitle(ViewModel.Zone), Mode=OneTime}"
                       Style="{StaticResource FPCaptionStyle}"
                       Foreground="{ThemeResource FPTextSecondaryBrush}"/>

            <!-- Meta grid 4-col: Account / Name servers / Plan / Added -->
            <Border Grid.Row="2"
                    Padding="16"
                    CornerRadius="{StaticResource FPCornerCard}"
                    Background="{ThemeResource FPMicaCardBrush}">
                <Grid ColumnSpacing="24" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Bind loc:L.S('zoneDetail_overline_account'), Mode=OneTime}"
                               Style="{StaticResource FPOverlineStyle}"
                               Foreground="{ThemeResource FPTextTertiaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{x:Bind ViewModel.Zone.AccountDisplay}"
                               Style="{StaticResource FPBodyStyle}"
                               Foreground="{ThemeResource FPTextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind loc:L.S('zoneDetail_overline_nameservers'), Mode=OneTime}"
                               Style="{StaticResource FPOverlineStyle}"
                               Foreground="{ThemeResource FPTextTertiaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{x:Bind ViewModel.Zone.NameServersDisplay}"
                               Style="{StaticResource FPMonoSmallStyle}"
                               Foreground="{ThemeResource FPTextPrimaryBrush}"
                               IsTextSelectionEnabled="True"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Bind loc:L.S('zoneDetail_overline_plan'), Mode=OneTime}"
                               Style="{StaticResource FPOverlineStyle}"
                               Foreground="{ThemeResource FPTextTertiaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="{x:Bind ViewModel.Zone.PlanDisplay}"
                               Style="{StaticResource FPBodyStyle}"
                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{x:Bind loc:L.S('zoneDetail_overline_added'), Mode=OneTime}"
                               Style="{StaticResource FPOverlineStyle}"
                               Foreground="{ThemeResource FPTextTertiaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3"
                               Text="{x:Bind ViewModel.Zone.CreatedOnDisplay}"
                               Style="{StaticResource FPBodyStyle}"
                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Status banner -->
            <Border Grid.Row="3"
                    Visibility="{x:Bind local:ZoneDetailView.BoolToVis(ViewModel.HasResult), Mode=OneWay}"
                    Padding="12,10"
                    CornerRadius="{StaticResource FPCornerControl}">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource FPAccentSubtle}"/>
                </Border.Background>
                <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}"
                           Style="{StaticResource FPBodyStyle}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Card 1: Purgar todo (flame) -->
            <Border Grid.Row="4"
                    Padding="16"
                    CornerRadius="{StaticResource FPCornerCard}"
                    Background="{ThemeResource FPMicaCardBrush}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="{ThemeResource FPAccentSubtleBrush}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEB51;"
                                  FontSize="18"
                                  Foreground="{ThemeResource FPAccentBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind loc:L.S('zoneDetail_purgeEverything_cta'), Mode=OneTime}"
                                   Style="{StaticResource FPTitleStyle}"
                                   Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind loc:L.S('zoneDetail_purgeEverything_subtitle'), Mode=OneTime}"
                                   Style="{StaticResource FPCaptionStyle}"
                                   Foreground="{ThemeResource FPTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="{x:Bind loc:L.S('zoneDetail_purgeEverything_cta'), Mode=OneTime}"
                            Click="OnPurgeEverythingClick"
                            IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Card 2: Purga selectiva (list icon) -->
            <Border Grid.Row="5"
                    Padding="16"
                    CornerRadius="{StaticResource FPCornerCard}"
                    Background="{ThemeResource FPMicaCardBrush}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="{ThemeResource FPMicaPanelBrush}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEA37;"
                                  FontSize="16"
                                  Foreground="{ThemeResource FPTextSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind loc:L.S('zoneDetail_purgeSelective_cta'), Mode=OneTime}"
                                   Style="{StaticResource FPTitleStyle}"
                                   Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind loc:L.S('zoneDetail_purgeSelective_subtitle'), Mode=OneTime}"
                                   Style="{StaticResource FPCaptionStyle}"
                                   Foreground="{ThemeResource FPTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="{x:Bind loc:L.S('zoneDetail_selectiveCtaArrow'), Mode=OneTime}"
                            Click="OnSelectivePurgeClick"
                            IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
