<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FlarePurge.App.Views.MainShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FlarePurge.App.Views"
    xmlns:loc="using:FlarePurge.App.Localization">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 3-column body: sidebar / zone list / detail -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════
                 Sidebar (column 0)
                 ═══════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{ThemeResource FPMicaPanelBrush}"
                    BorderBrush="{ThemeResource FPBorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="12,16" Spacing="4">

                        <!-- CUENTAS API overline -->
                        <TextBlock Text="{x:Bind loc:L.S('sidebar_apiAccounts'), Mode=OneTime}"
                                   Style="{StaticResource FPOverlineStyle}"
                                   Margin="8,4,8,8"/>

                        <!-- Accounts list (built in code-behind so we can highlight the active one) -->
                        <StackPanel x:Name="AccountsList" Spacing="2"/>

                        <!-- Add API key -->
                        <Button Click="OnAddAccountClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,6"
                                Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;"
                                          FontSize="14"
                                          Foreground="{ThemeResource FPAccentBrush}"/>
                                <TextBlock Text="{x:Bind loc:L.S('accounts_add'), Mode=OneTime}"
                                           Style="{StaticResource FPBodyStyle}"
                                           Foreground="{ThemeResource FPAccentBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <!-- NAVEGAR overline -->
                        <TextBlock Text="{x:Bind loc:L.S('sidebar_sections'), Mode=OneTime}"
                                   Style="{StaticResource FPOverlineStyle}"
                                   Margin="8,20,8,8"/>

                        <!-- Zonas -->
                        <Button x:Name="NavZonesButton"
                                Click="OnNavZonesClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,8"
                                Margin="0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border x:Name="NavZonesIndicator"
                                        Width="3" Height="16"
                                        Background="{ThemeResource FPAccentBrush}"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Visibility="Visible"/>
                                <FontIcon Glyph="&#xE774;" FontSize="14"
                                          Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind loc:L.S('sidebar_zones'), Mode=OneTime}"
                                           Style="{StaticResource FPBodyStyle}"
                                           Foreground="{ThemeResource FPTextPrimaryBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <!-- Ajustes -->
                        <Button x:Name="NavSettingsButton"
                                Click="OnNavSettingsClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,8"
                                Margin="0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border x:Name="NavSettingsIndicator"
                                        Width="3" Height="16"
                                        Background="{ThemeResource FPAccentBrush}"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                                <FontIcon Glyph="&#xE713;" FontSize="14"
                                          Foreground="{ThemeResource FPTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind loc:L.S('sidebar_settings'), Mode=OneTime}"
                                           Style="{StaticResource FPBodyStyle}"
                                           Foreground="{ThemeResource FPTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <!-- Acerca de -->
                        <Button x:Name="NavAboutButton"
                                Click="OnNavAboutClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,8"
                                Margin="0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border x:Name="NavAboutIndicator"
                                        Width="3" Height="16"
                                        Background="{ThemeResource FPAccentBrush}"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                                <FontIcon Glyph="&#xE946;" FontSize="14"
                                          Foreground="{ThemeResource FPTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind loc:L.S('about_menuTitle'), Mode=OneTime}"
                                           Style="{StaticResource FPBodyStyle}"
                                           Foreground="{ThemeResource FPTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══════════════════════════════════════════
                 Zone list column (column 1)
                 ═══════════════════════════════════════════ -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource FPBorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <ContentControl x:Name="ListHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
            </Border>

            <!-- ═══════════════════════════════════════════
                 Detail column (column 2)
                 ═══════════════════════════════════════════ -->
            <Grid Grid.Column="2">
                <ContentControl x:Name="DetailHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>

                <!-- Empty selection (shown when DetailHost.Content is null) -->
                <StackPanel x:Name="EmptySelectionPanel"
                            Spacing="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="360"
                            Visibility="Collapsed">
                    <Border Width="80" Height="80"
                            CornerRadius="40"
                            Background="{ThemeResource FPAccentSubtleBrush}"
                            HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE7E8;"
                                  FontSize="32"
                                  Foreground="{ThemeResource FPAccentBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="§ LISTO"
                               Style="{StaticResource FPOverlineStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="Selecciona una zona para ver los detalles"
                               Style="{StaticResource FPTitleStyle}"
                               Foreground="{ThemeResource FPTextPrimaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Toca una zona de la lista para purgarla, ver su historial o ajustar su configuración."
                               Style="{StaticResource FPCaptionStyle}"
                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             Status bar (row 1)
             ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{ThemeResource FPMicaPanelBrush}"
                BorderBrush="{ThemeResource FPBorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{ThemeResource FPSuccessBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind loc:L.S('mac_status_connected'), Mode=OneTime}"
                               Style="{StaticResource FPCaptionTertiaryStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="LastUpdatedText"
                           Grid.Column="1"
                           Style="{StaticResource FPCaptionTertiaryStyle}"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <HyperlinkButton x:Name="RefreshZonesButton"
                                 Grid.Column="2"
                                 Click="OnRefreshZonesClick"
                                 Padding="6,2"
                                 Margin="4,0,0,0"
                                 VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        <TextBlock Text="{x:Bind loc:L.S('status_refresh'), Mode=OneTime}"
                                   Style="{StaticResource FPCaptionTertiaryStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Grid.Column="3"
                                 Click="OnHistoryClick"
                                 Padding="6,2"
                                 VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE823;" FontSize="12"/>
                        <TextBlock Text="{x:Bind loc:L.S('sidebar_history'), Mode=OneTime}"
                                   Style="{StaticResource FPCaptionTertiaryStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>
                <TextBlock Grid.Column="4"
                           Text="{x:Bind loc:L.S('mac_status_keychain'), Mode=OneTime}"
                           Style="{StaticResource FPCaptionTertiaryStyle}"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
