<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FlarePurge.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FlarePurge.App.ViewModels"
    xmlns:loc="using:FlarePurge.App.Localization">

    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator Key="Escape" Invoked="OnEscape"/>
    </UserControl.KeyboardAccelerators>

    <Grid Padding="4,4,4,8" RowSpacing="8" MinWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="HeaderPanel" Grid.Row="0" Spacing="2" Margin="6,0,6,0">
            <TextBlock Text="§ AJUSTES" Style="{StaticResource FPOverlineStyle}"/>
            <TextBlock Text="{x:Bind loc:L.S('settings_title'), Mode=OneTime}"
                       Style="{StaticResource FPDisplayStyle}"
                       Foreground="{ThemeResource FPTextPrimaryBrush}"/>
        </StackPanel>

        <Pivot Grid.Row="1">
            <PivotItem Header="{x:Bind loc:L.S('prefs_general'), Mode=OneTime}" Margin="0,8,0,0">
                <StackPanel Spacing="12">

                    <!-- APARIENCIA -->
                    <Border Padding="14"
                            CornerRadius="{StaticResource FPCornerCard}"
                            Background="{ThemeResource FPMicaCardBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind loc:L.S('settings_section_appearance'), Mode=OneTime}"
                                       Style="{StaticResource FPTitleStyle}"
                                       Foreground="{ThemeResource FPTextPrimaryBrush}"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind loc:L.S('settings_colorScheme'), Mode=OneTime}"
                                               Style="{StaticResource FPBodyStyle}"
                                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind loc:L.S('prefs_appearance_footer'), Mode=OneTime}"
                                               Style="{StaticResource FPCaptionStyle}"
                                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{x:Bind ViewModel.ThemeOptions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          MinWidth="180"/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind loc:L.S('settings_language'), Mode=OneTime}"
                                               Style="{StaticResource FPBodyStyle}"
                                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind loc:L.S('settings_language_footer'), Mode=OneTime}"
                                               Style="{StaticResource FPCaptionStyle}"
                                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          MinWidth="220"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SEGURIDAD -->
                    <Border Padding="14"
                            CornerRadius="{StaticResource FPCornerCard}"
                            Background="{ThemeResource FPMicaCardBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind loc:L.S('settings_section_security'), Mode=OneTime}"
                                       Style="{StaticResource FPTitleStyle}"
                                       Foreground="{ThemeResource FPTextPrimaryBrush}"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind loc:L.S('settings_confirmPurgeAll'), Mode=OneTime}"
                                               Style="{StaticResource FPBodyStyle}"
                                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind loc:L.S('settings_confirmPurgeAll_desc'), Mode=OneTime}"
                                               Style="{StaticResource FPCaptionStyle}"
                                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind ViewModel.ConfirmPurgeEverything, Mode=TwoWay}"
                                              OnContent="" OffContent=""/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind loc:L.S('settings_confirmPurgeSelective'), Mode=OneTime}"
                                               Style="{StaticResource FPBodyStyle}"
                                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind loc:L.S('settings_confirmPurgeSelective_desc'), Mode=OneTime}"
                                               Style="{StaticResource FPCaptionStyle}"
                                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind ViewModel.ConfirmBulkPurge, Mode=TwoWay}"
                                              OnContent="" OffContent=""/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- VENTANA -->
                    <Border Padding="14"
                            CornerRadius="{StaticResource FPCornerCard}"
                            Background="{ThemeResource FPMicaCardBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind loc:L.S('settings_section_window'), Mode=OneTime}"
                                       Style="{StaticResource FPTitleStyle}"
                                       Foreground="{ThemeResource FPTextPrimaryBrush}"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind loc:L.S('settings_window_minimize'), Mode=OneTime}"
                                               Style="{StaticResource FPBodyStyle}"
                                               Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind loc:L.S('settings_window_minimize_desc'), Mode=OneTime}"
                                               Style="{StaticResource FPCaptionStyle}"
                                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"
                                              OnContent="" OffContent=""/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </PivotItem>

            <PivotItem Header="{x:Bind loc:L.S('sidebar_apiAccounts'), Mode=OneTime}" Margin="0,8,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="{x:Bind loc:L.S('accounts_footer'), Mode=OneTime}"
                               Style="{StaticResource FPCaptionStyle}"
                               Foreground="{ThemeResource FPTextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Border Padding="6"
                            CornerRadius="{StaticResource FPCornerCard}"
                            Background="{ThemeResource FPMicaCardBrush}">
                        <StackPanel x:Name="AccountsList" Spacing="2"/>
                    </Border>

                    <Button Click="OnAddAccountClick"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="{x:Bind loc:L.S('accounts_add'), Mode=OneTime}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </PivotItem>
        </Pivot>
    </Grid>
</UserControl>
