<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FlarePurge.App.Views.ZoneListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FlarePurge.App.Views"
    xmlns:vm="using:FlarePurge.App.ViewModels"
    xmlns:loc="using:FlarePurge.App.Localization">

    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="OnCtrlR"/>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnCtrlF"/>
    </UserControl.KeyboardAccelerators>

    <Grid Padding="16" RowSpacing="12">
        <Grid.Resources>
            <CollectionViewSource x:Name="GroupedZonesSource"
                                  IsSourceGrouped="True"
                                  Source="{x:Bind ViewModel.ZonesGrouped, Mode=OneWay}"/>
            <Style x:Key="ZoneListItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="8,8"/>
                <Setter Property="Margin" Value="0,1"/>
                <Setter Property="CornerRadius" Value="{StaticResource FPCornerControl}"/>
            </Style>
            <DataTemplate x:Key="ZoneListItemTemplate" x:DataType="vm:ZoneDisplayItem">
                <Grid ColumnSpacing="10">
                    <Grid.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="{x:Bind loc:L.S('mac_purge_cta_all'), Mode=OneTime}"
                                            Tag="{x:Bind}"
                                            Click="OnContextPurgeClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8BB;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{x:Bind loc:L.S('mac_purge_cta_selective'), Mode=OneTime}"
                                            Tag="{x:Bind}"
                                            Click="OnContextOpenDetailClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <ToggleMenuFlyoutItem Text="{x:Bind loc:L.S('zoneList_ctxFavourite'), Mode=OneTime}"
                                                  IsChecked="{x:Bind IsFavorite, Mode=TwoWay}"
                                                  Tag="{x:Bind}"
                                                  Click="OnContextFavoriteClick"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="{x:Bind loc:L.S('ios_zone_copyId'), Mode=OneTime}"
                                            Tag="{x:Bind}"
                                            Click="OnContextCopyIdClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C8;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Grid.ContextFlyout>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton Grid.Column="0"
                                  IsChecked="{x:Bind IsFavorite, Mode=TwoWay}"
                                  Checked="OnFavoriteToggled"
                                  Unchecked="OnFavoriteToggled"
                                  ToolTipService.ToolTip="{x:Bind loc:L.S('zoneList_ctxFavourite'), Mode=OneTime}"
                                  AutomationProperties.Name="{x:Bind loc:L.S('zoneList_ctxFavouriteTooltip'), Mode=OneTime}"
                                  VerticalAlignment="Center"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="6"
                                  MinWidth="32"
                                  MinHeight="32">
                        <FontIcon Glyph="&#xE735;" FontSize="12"
                                  AutomationProperties.AccessibilityView="Raw"/>
                    </ToggleButton>
                    <Ellipse Grid.Column="1"
                             Width="8" Height="8"
                             VerticalAlignment="Center"
                             AutomationProperties.AccessibilityView="Raw"
                             Fill="{x:Bind local:ZoneListView.StatusBrush(IsActive)}"/>
                    <TextBlock Grid.Column="2"
                               Text="{x:Bind Name}"
                               Style="{StaticResource FPBodyStyle}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="{x:Bind loc:L.S('zoneList_overline'), Mode=OneTime}" Style="{StaticResource FPOverlineStyle}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind loc:L.S('sidebar_zones'), Mode=OneTime}"
                           Style="{StaticResource FPH2Style}"
                           Foreground="{ThemeResource FPTextPrimaryBrush}"/>
                <Button Grid.Column="1"
                        Content="{x:Bind local:ZoneListView.FavouritesButtonLabel(ViewModel.FavoriteCount), Mode=OneWay}"
                        Click="OnPurgeFavoritesClick"
                        Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.HasFavorites), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Center"
                        Padding="10,4"/>
            </Grid>
            <TextBlock Text="{x:Bind local:ZoneListView.ZoneCountLabel(ViewModel.Zones.Count), Mode=OneWay}"
                       Style="{StaticResource FPCaptionTertiaryStyle}"/>
        </StackPanel>

        <!-- Search + account filter + bulk-account button -->
        <Grid Grid.Row="1" RowSpacing="8"
              Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.ShowSearchBox), Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0"
                     x:Name="SearchBox"
                     PlaceholderText="{x:Bind loc:L.S('zoneList_filterPlaceholder'), Mode=OneTime}"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <ComboBox Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.AvailableAccountFilters, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedAccountFilter, Mode=TwoWay}"
                      Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.ShowAccountFilter), Mode=OneWay}"
                      HorizontalAlignment="Stretch"/>
            <Button Grid.Row="2"
                    Content="{x:Bind local:ZoneListView.PurgeAccountLabel(ViewModel.AccountFilterZoneCount, ViewModel.SelectedAccountFilter), Mode=OneWay}"
                    Click="OnPurgeAccountClick"
                    Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.HasAccountFilterActive), Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="10,6"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="3">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.IsLoading), Mode=OneWay}"
                          Width="28" Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <StackPanel Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.HasError), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        MaxWidth="260">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource FPBodyStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <Button Content="{x:Bind loc:L.S('action_retry'), Mode=OneTime}"
                        Command="{x:Bind ViewModel.LoadCommand}"
                        Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.ShowRetry), Mode=OneWay}"
                        HorizontalAlignment="Center"/>
                <Button Content="{x:Bind loc:L.S('zoneList_addToken'), Mode=OneTime}"
                        Click="OnReauthClick"
                        Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.ShowReauth), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.IsEmpty), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        MaxWidth="260">
                <FontIcon Glyph="&#xE7BE;"
                          FontSize="28"
                          Foreground="{ThemeResource FPTextTertiaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind loc:L.S('zoneList_emptyTitle'), Mode=OneTime}"
                           Style="{StaticResource FPBodyLargeStyle}"
                           Foreground="{ThemeResource FPTextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind loc:L.S('zoneList_emptySubtitle'), Mode=OneTime}"
                           Style="{StaticResource FPCaptionStyle}"
                           Foreground="{ThemeResource FPTextSecondaryBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </StackPanel>

            <StackPanel Visibility="{x:Bind local:ZoneListView.BoolToVis(ViewModel.IsSearchEmpty), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        MaxWidth="260">
                <TextBlock Text="{x:Bind loc:L.S('zoneList_searchEmpty'), Mode=OneTime}"
                           Style="{StaticResource FPBodyStyle}"
                           Foreground="{ThemeResource FPTextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <Button Content="{x:Bind loc:L.S('zoneList_searchClear'), Mode=OneTime}"
                        Command="{x:Bind ViewModel.ClearSearchCommand}"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <ListView x:Name="FlatZoneList"
                      Visibility="{x:Bind local:ZoneListView.FlatListVis(ViewModel.HasZones, ViewModel.UseGroupedView), Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.Zones, Mode=OneWay}"
                      ItemContainerStyle="{StaticResource ZoneListItemContainerStyle}"
                      ItemTemplate="{StaticResource ZoneListItemTemplate}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnZoneItemClick"/>

            <ListView x:Name="GroupedZoneList"
                      Visibility="{x:Bind local:ZoneListView.GroupedListVis(ViewModel.HasZones, ViewModel.UseGroupedView), Mode=OneWay}"
                      ItemsSource="{x:Bind GroupedZonesSource.View, Mode=OneWay}"
                      ItemContainerStyle="{StaticResource ZoneListItemContainerStyle}"
                      ItemTemplate="{StaticResource ZoneListItemTemplate}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnZoneItemClick">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="vm:ZoneGroup">
                                <TextBlock Text="{x:Bind Key}"
                                           Style="{StaticResource FPOverlineStyle}"
                                           Foreground="{ThemeResource FPTextTertiaryBrush}"
                                           Margin="8,12,0,2"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
